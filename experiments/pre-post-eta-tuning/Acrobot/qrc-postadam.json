{
    "agent": "QRCPostAdam",
    "problem": "Acrobot",
    "total_steps": 100000,
    "episode_cutoff": 500,
    "metaParameters": {
        "epsilon": 0.1,
        "buffer_type": "iid",

        "buffer_size": 10000,
        "batch": 64,

        "beta": 1.0,
        "eta": [0.125, 0.25, 0.5, 1.0, 2.0, 4.0, 8.0],

        "optimizer": {
            "name": "ADAM",
            "learning_rate": 0.001,
            "b1": 0.9,
            "b2": 0.999,
            "eps": 1e-8
        },

        "representation": {
            "type": "TwoLayerRelu",
            "hidden": 64
        }
    }
}
