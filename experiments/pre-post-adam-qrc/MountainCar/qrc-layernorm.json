        "optimizer": {
            "name": "ADAM",
            "learning_rate": 0.001,
            "b1": 0.9,
            "b2": 0.999,
            "eps": 1e-8
        },

        "representation": {
            "type": "TwoLayerReluLayerNorm",
            "hidden": 64
        }
    }
}
