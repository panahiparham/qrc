{
    "agent": "QRC",
    "problem": "MountainCar",
    "total_steps": 100000,
    "episode_cutoff": 1000,
    "metaParameters": {
        "epsilon": 0.1,
        "buffer_type": "iid",

        "buffer_size": 10000,
        "batch": 64,

        "beta": 1.0,
